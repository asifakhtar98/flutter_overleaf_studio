# =============================================================================
# TeX Live Compilation API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Required ---
# Comma-separated list of valid API keys
API_KEYS=dev-key-change-me-in-production

# --- CORS ---
# Comma-separated allowed origins (use * for dev, lock down in prod)
ALLOWED_ORIGINS=*

# --- Limits ---
# Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=50

# Compilation timeout in seconds
COMPILATION_TIMEOUT=120

# Rate limit per API key (SlowAPI format)
RATE_LIMIT=30/minute

# --- Logging ---
LOG_LEVEL=info

# --- Server ---
# Uvicorn worker count (prod only; dev always uses 1 with --reload)
WORKERS=4

# --- Performance: Cache ---
# Max entries in the in-memory LRU compile cache
CACHE_MAX_SIZE=200

# Cache TTL in seconds (default: 30 minutes)
CACHE_TTL_SECONDS=1800

# --- Performance: Compilation ---
# Use /dev/shm (tmpfs / RAM-disk) for temp dirs
USE_TMPFS=true

# Max concurrent compilations (should match OCPU count)
MAX_CONCURRENT_COMPILES=4
